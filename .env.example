JWT_SECRET=replace_with_a_long_random_secret
# encrypts each user's own BYOK API keys at rest (AES-256-GCM) — required in
# production. Generate one with: openssl rand -hex 32
KEY_ENCRYPTION_SECRET=replace_with_a_different_long_random_secret

# ---- Pooled "Default (Free)" tier ----
# The only provider key the OPERATOR needs to supply. Every visitor without
# their own key shares this one, via OpenRouter's free-tier models. Get a
# key at openrouter.ai/keys
# OpenRouter's free-tier ":free" models rotate and get pulled without notice -
# if analysis starts failing with a 404 "model has been deprecated" error,
# check openrouter.ai/models for a current replacement and update this.
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# if the pinned model above fails outright (retries exhausted), automatically retry once
# against this one instead of just erroring - openrouter/free is OpenRouter's own router
# across whatever free models are currently live, so it self-heals the exact kind of
# deprecation that just broke the previous default.
OPENROUTER_FALLBACK_MODEL=openrouter/free

# ---- Legacy pooled tier, not used by default anymore ----
# Groq's provider code is still fully functional (see router.py) - it's just
# not what "Default (Free)" resolves to. Switch resolveProviderForRequest()
# in server/userKeys.js back to "groq" if you ever want it again.
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=qwen/qwen3.6-27b

# ---- BYOK model defaults (used when a user brings their own key) ----
# Env-overridable rather than hardcoded, since provider model IDs change —
# double check these against current provider docs before deploying.
GEMINI_DEFAULT_MODEL=gemini-3.5-flash
CLAUDE_DEFAULT_MODEL=claude-4-5-sonnet-latest
OPENAI_DEFAULT_MODEL=gpt-4o

# ---- Optional: LinkedIn OAuth (public profile import) ----
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ---- Critic (agentic self-correction) ----
# true: critic re-checks a rewrite using the same provider/key as the main
# request. false: critic always uses CRITIC_PROVIDER/CRITIC_API_KEY below,
# no matter what the user picked as their main provider. Either way,
# CRITIC_MODEL (if set) always overrides just the model - the critic can run
# a different model from the main agent even while sharing its provider/key.
# Left blank here on purpose: with CRITIC_SAME_AS_MAIN=true and no override, the
# critic just inherits whatever model the main request used (nemotron-3-ultra by
# default, above) - fill this in only if you want the critic pinned to a model
# that's deliberately different from whatever main ends up using.
CRITIC_SAME_AS_MAIN=true
CRITIC_PROVIDER=openrouter
CRITIC_API_KEY=
CRITIC_MODEL=

ALLOW_MENTOR_REGISTRATION=false
# minutes to reuse a cached analysis for an identical resume + job description
# + provider/critic combination instead of calling the LLM again; 0 disables
ANALYSIS_CACHE_TTL_MINUTES=60
# bullets batched into a single LLM call during resume analysis
REWRITE_CHUNK_SIZE=6
# public hostname for HTTPS deployment via docker-compose.https.yml
DOMAIN=
