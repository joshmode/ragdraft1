JWT_SECRET=replace_with_a_long_random_secret
# encrypts each user's own BYOK API keys at rest (AES-256-GCM) — required in
# production. Generate one with: openssl rand -hex 32
KEY_ENCRYPTION_SECRET=replace_with_a_different_long_random_secret

# ---- Pooled "Default (Free)" tier ----
# The only provider key the OPERATOR needs to supply. Every visitor without
# their own key shares this one, via Groq's free tier. Get a key at
# console.groq.com/keys
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# ---- BYOK model defaults (used when a user brings their own key) ----
# Env-overridable rather than hardcoded, since provider model IDs change —
# double check these against current provider docs before deploying.
GEMINI_DEFAULT_MODEL=gemini-3.5-flash
CLAUDE_DEFAULT_MODEL=claude-4-5-sonnet-latest
OPENAI_DEFAULT_MODEL=gpt-4o

# ---- Optional: LinkedIn OAuth (public profile import) ----
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ---- Critic (agentic self-correction) ----
# true: critic re-checks a rewrite using the same provider/key as the main
# request. false: critic always uses CRITIC_PROVIDER/CRITIC_API_KEY below,
# no matter what the user picked as their main provider.
CRITIC_SAME_AS_MAIN=true
CRITIC_PROVIDER=groq
CRITIC_API_KEY=
CRITIC_MODEL=

ALLOW_MENTOR_REGISTRATION=false
# minutes to reuse a cached analysis for an identical resume + job description
# + provider/critic combination instead of calling the LLM again; 0 disables
ANALYSIS_CACHE_TTL_MINUTES=60
# bullets batched into a single LLM call during resume analysis
REWRITE_CHUNK_SIZE=6
# public hostname for HTTPS deployment via docker-compose.https.yml
DOMAIN=
